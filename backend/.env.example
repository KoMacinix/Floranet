# =============================================================================
# Backend - Variables d'environnement
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs

# --- PostgreSQL (Docker) ---
# Doit correspondre aux valeurs utilisées dans docker run
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fire_detection_db
DB_USER=postgres
DB_PASSWORD=ton_mot_de_passe

# --- InfluxDB (optionnel) ---
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token_here
INFLUXDB_ORG=your_org_here
INFLUXDB_BUCKET=fire-detection

# --- LoRa Serial ---
LORA_PORT=COM3
LORA_BAUDRATE=115200

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
